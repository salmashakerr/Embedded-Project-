import socket
import threading
import time
import sys

ESP_IP = "192.168.4.1"
ESP_PORT = 333

def receive_loop(sock):
    """Continuously receive and print messages from the robot."""
    buffer = ""
    while True:
        try:
            data = sock.recv(1024).decode("utf-8", errors="replace")
            if not data:
                print("\n[Disconnected from robot]")
                break
            buffer += data
            while "\n" in buffer:
                line, buffer = buffer.split("\n", 1)
                line = line.strip()
                if line:
                    # Filter out AT command garbage
                    if line.startswith("AT+") or line == "OK" or line == ">" or line.startswith("SEND") or line.startswith("Recv"):
                        continue
                    print(f"  ROBOT > {line}")
        except Exception as e:
            print(f"\n[Connection lost: {e}]")
            break

def main():
    print("=" * 50)
    print("       MAZE ROBOT CONTROLLER")
    print("=" * 50)
    print()
    print("Make sure you are connected to WiFi: MazeRobot")
    print("Password: 12345678")
    print()
    print(f"Connecting to {ESP_IP}:{ESP_PORT}...")

    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        sock.connect((ESP_IP, ESP_PORT))
        sock.settimeout(None)
        print("[Connected to robot!]")
        print()
    except Exception as e:
        print(f"[Failed to connect: {e}]")
        print("Check that you are on the MazeRobot WiFi network.")
        sys.exit(1)

    # Start background thread to print incoming messages
    rx_thread = threading.Thread(target=receive_loop, args=(sock,), daemon=True)
    rx_thread.start()

    print("-" * 50)
    print("  COMMANDS:")
    print("  TRAIN  - Start training (LSRB exploration)")
    print("  SOLVE  - Run the shortest path")
    print("  STATUS - Show current state & saved path")
    print("  STOP   - Stop the robot")
    print("  RESET  - Clear saved path for new maze")
    print("  QUIT   - Exit this program")
    print("-" * 50)

    while True:
        try:
            cmd = input("\nCommand > ").strip().upper()
            if cmd == "QUIT":
                print("Goodbye!")
                sock.close()
                break
            if cmd:
                sock.send((cmd + "\r\n").encode())
                time.sleep(0.1)
        except (KeyboardInterrupt, EOFError):
            print("\nGoodbye!")
            sock.close()
            break

if __name__ == "__main__":
    main()
