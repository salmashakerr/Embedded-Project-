<script>
let isConnected = false;
let lastMsgCount = 0;
let pollInterval = null;

function toggleConnect() {
  if (isConnected) {
    fetch('/disconnect').then(r => r.json()).then(d => {
      isConnected = false;
      updateConnUI();
    });
  } else {
    const ip = document.getElementById('ipInput').value;
    const port = document.getElementById('portInput').value;
    fetch('/connect?ip=' + ip + '&port=' + port)
      .then(r => r.json())
      .then(d => {
        isConnected = d.ok;
        updateConnUI();
        if (isConnected && !pollInterval) {
          pollInterval = setInterval(pollMessages, 300);
        }
      });
  }
}

function updateConnUI() {
  const dot = document.getElementById('statusDot');
  const btn = document.getElementById('connBtn');
  if (isConnected) {
    dot.classList.add('on');
    btn.textContent = 'Disconnect';
    btn.className = 'btn btn-disconnect';
  } else {
    dot.classList.remove('on');
    btn.textContent = 'Connect';
    btn.className = 'btn btn-connect';
  }
}

function sendCmd(cmd) {
  fetch('/send?cmd=' + encodeURIComponent(cmd))
    .then(r => r.json());
}

function pollMessages() {
  fetch('/messages?after=' + lastMsgCount)
    .then(r => r.json())
    .then(data => {
      isConnected = data.connected;
      updateConnUI();

      if (data.msgs.length > 0) {
        const log = document.getElementById('logArea');
        data.msgs.forEach(m => {
          const div = document.createElement('div');
          div.className = 'log-line';

          const timeSpan = document.createElement('span');
          timeSpan.className = 'log-time';
          timeSpan.textContent = m.time;

          const srcSpan = document.createElement('span');
          srcSpan.className = 'log-src-' + m.source.toLowerCase();
          srcSpan.textContent = m.source;

          const textSpan = document.createElement('span');
          textSpan.className = 'log-text';
          textSpan.textContent = m.text;

          if (m.text.includes('TRAINING_COMPLETE') ||
              m.text.includes('MAZE_SOLVED') ||
              m.text.includes('SHORTEST_PATH')) {
            textSpan.classList.add('highlight');
          }

          // Update path displays
          if (m.text.startsWith('TRAINING_COMPLETE:')) {
            const trainEl = document.getElementById('trainPath');
            trainEl.textContent = m.text.split(':')[1];
            trainEl.className = 'path-moves';
          }
          if (m.text.startsWith('SHORTEST_PATH:')) {
            document.getElementById('solvePath').textContent = m.text.split(':')[1];
          }
          if (m.text.startsWith('SAVED_PATH:')) {
            document.getElementById('solvePath').textContent = m.text.split(':')[1];
          }

          // Clear path displays on reset
          if (m.text.includes('EEPROM_CLEARED')) {
            document.getElementById('trainPath').textContent = '--';
            document.getElementById('trainPath').className = 'path-moves';
            document.getElementById('solvePath').textContent = '--';
            document.getElementById('solvePath').className = 'path-moves solved';
          }

          // Show running state on new training
          if (m.text.includes('STATE:TRAINING')) {
            const trainEl = document.getElementById('trainPath');
            trainEl.textContent = 'Running...';
            trainEl.className = 'path-moves running';
            document.getElementById('solvePath').textContent = '--';
            document.getElementById('solvePath').className = 'path-moves solved';
          }

          // Show running state on solve
          if (m.text.includes('STATE:SOLVING')) {
            const solveEl = document.getElementById('solvePath');
            solveEl.className = 'path-moves running';
          }

          // Restore solved color when done
          if (m.text.includes('MAZE_SOLVED')) {
            const solveEl = document.getElementById('solvePath');
            solveEl.className = 'path-moves solved';
          }

          div.appendChild(timeSpan);
          div.appendChild(srcSpan);
          div.appendChild(textSpan);
          log.appendChild(div);
        });
        log.scrollTop = log.scrollHeight;
        lastMsgCount = data.total;
      }
    });
}

pollInterval = setInterval(pollMessages, 300);

document.addEventListener('keydown', (e) => {
  if (e.target.tagName === 'INPUT') return;
  switch(e.key) {
    case 'ArrowUp': case 'w': sendCmd('FWD'); break;
    case 'ArrowLeft': case 'a': sendCmd('MLEFT'); break;
    case 'ArrowRight': case 'd': sendCmd('MRIGHT'); break;
    case 'ArrowDown': case 's': sendCmd('MBACK'); break;
    case ' ': sendCmd('MSTOP'); e.preventDefault(); break;
  }
});

document.addEventListener('keyup', (e) => {
  if (e.target.tagName === 'INPUT') return;
  if (['ArrowUp','ArrowLeft','ArrowRight','ArrowDown','w','a','s','d'].includes(e.key)) {
    sendCmd('MSTOP');
  }
});
</script>
</body>
</html>
"""

# ========== HTTP SERVER ==========
class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path
        params = parse_qs(parsed.query)

        if path == '/':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(HTML_PAGE.encode())

        elif path == '/connect':
            ip = params.get('ip', ['192.168.4.1'])[0]
            port = params.get('port', ['333'])[0]
            ok = connect_robot(ip, int(port))
            self.json_response({'ok': ok})

        elif path == '/disconnect':
            disconnect_robot()
            self.json_response({'ok': True})

        elif path == '/send':
            cmd = params.get('cmd', [''])[0]
            ok = send_command(cmd)
            self.json_response({'ok': ok})

        elif path == '/messages':
            after = int(params.get('after', ['0'])[0])
            with msg_lock:
                new_msgs = messages[after:]
                total = len(messages)
            self.json_response({
                'msgs': new_msgs,
                'total': total,
                'connected': connected
            })

        else:
            self.send_response(404)
            self.end_headers()

    def json_response(self, data):
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def log_message(self, format, *args):
        pass

# ========== MAIN ==========
