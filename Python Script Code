# ========== ROBOT CONNECTION ==========
robot_socket = None
connected = False
messages = []
msg_lock = threading.Lock()

def connect_robot(ip, port):
    global robot_socket, connected
    try:
        robot_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        robot_socket.settimeout(5)
        robot_socket.connect((ip, int(port)))
        robot_socket.settimeout(None)
        connected = True
        add_message("SYSTEM", "Connected to robot!")
        t = threading.Thread(target=receive_loop, daemon=True)
        t.start()
        return True
    except Exception as e:
        add_message("SYSTEM", f"Connection failed: {e}")
        connected = False
        return False

def disconnect_robot():
    global robot_socket, connected
    if robot_socket:
        try:
            robot_socket.close()
        except:
            pass
    robot_socket = None
    connected = False
    add_message("SYSTEM", "Disconnected")

def send_command(cmd):
    global robot_socket, connected
    if not connected or not robot_socket:
        add_message("SYSTEM", "Not connected!")
        return False
    try:
        robot_socket.send((cmd + "\r\n").encode())
        add_message("YOU", cmd)
        return True
    except Exception as e:
        add_message("SYSTEM", f"Send failed: {e}")
        connected = False
        return False

def receive_loop():
    global connected
    buffer = ""
    while connected:
        try:
            data = robot_socket.recv(1024).decode("utf-8", errors="replace")
            if not data:
                add_message("SYSTEM", "Connection closed by robot")
                connected = False
                break
            buffer += data
            while "\n" in buffer:
                line, buffer = buffer.split("\n", 1)
                line = line.strip()
                if line and not is_at_garbage(line):
                    add_message("ROBOT", line)
        except Exception as e:
            if connected:
                add_message("SYSTEM", f"Connection lost: {e}")
                connected = False
            break

def is_at_garbage(line):
    garbage = ["AT+", "OK", ">", "SEND OK", "Recv", "busy", "link is not", "CLOSED", "CONNECT"]
    for g in garbage:
        if line.startswith(g):
            return True
    return False

def add_message(source, text):
    with msg_lock:
        messages.append({
            "source": source,
            "text": text,
            "time": time.strftime("%H:%M:%S")
        })
        if len(messages) > 200:
            messages.pop(0)

